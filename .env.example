cat > .env.example << 'EOF'
# Copy to .env and `set -a; source .env; set +a` before running uvicorn --
# this repo has no python-dotenv, so nothing loads .env automatically.

# --- Required ---
K8S_NAMESPACE=gpu-jobs
DATABASE_URL=postgresql://postgres:secret@127.0.0.1:5432/postgres?sslmode=disable

# --- Output uploads (GCS via Workload Identity) ---
# Job pods upload /outputs to this bucket. No credentials needed --
# pods authenticate via Workload Identity (gpu-job-sa -> gpu-worker-sa).
GCS_BUCKET=gpujob-outputs-shared

# --- Optional: GPU (off by default; jobs run on CPU) ---
# GPU_ENABLED=true
# GPU_ACCELERATOR_TYPE=nvidia-l4

# --- Optional: pod service account (default gpu-job-sa) ---
# POD_SERVICE_ACCOUNT=gpu-job-sa
EOF